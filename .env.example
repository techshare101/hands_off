# HandOff Environment Configuration
# Copy this to .env.local and fill in your values

# ── LLM Provider Keys (BYOK — pick any or multiple) ──────────────

# Google Gemini (get from https://aistudio.google.com/apikey)
VITE_GEMINI_API_KEY=your_gemini_key_here

# OpenAI (get from https://platform.openai.com/api-keys)
VITE_OPENAI_API_KEY=your_openai_key_here

# Anthropic / Claude (get from https://console.anthropic.com/settings/keys)
VITE_ANTHROPIC_API_KEY=your_anthropic_key_here

# Groq (get from https://console.groq.com/keys)
VITE_GROQ_API_KEY=your_groq_key_here

# DeepSeek (get from https://platform.deepseek.com/api_keys)
VITE_DEEPSEEK_API_KEY=your_deepseek_key_here

# Qwen / DashScope (get from https://dashscope.console.aliyun.com/apiKey)
VITE_QWEN_API_KEY=your_qwen_key_here

# Mistral (get from https://console.mistral.ai/api-keys)
VITE_MISTRAL_API_KEY=your_mistral_key_here

# OpenRouter (get from https://openrouter.ai/keys)
VITE_OPENROUTER_API_KEY=your_openrouter_key_here

# RouteLLM (get from https://routellm.ai)
VITE_ROUTELLM_API_KEY=your_routellm_key_here

# ── Options ───────────────────────────────────────────────────────

# Optional: Enable debug mode
VITE_DEBUG=false

# Optional: Max iterations per task (default: 50)
VITE_MAX_ITERATIONS=50
